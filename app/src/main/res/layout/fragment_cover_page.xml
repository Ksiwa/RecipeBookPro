<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_plain_paper"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="32dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/great_vibes"
                android:gravity="center"
                android:text="@string/my_recipe_book"
                android:textColor="#111111"
                android:textSize="56sp"
                android:textStyle="bold" />

            <View
                android:layout_width="120dp"
                android:layout_height="2dp"
                android:layout_marginTop="16dp"
                android:background="#33000000" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvCoverOwner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/indie_flower"
                android:gravity="center"
                android:textColor="#555555"
                android:textSize="24sp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvCoverCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_book_cover_label"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:fontFamily="@font/indie_flower"
                android:textColor="#333333"
                android:textSize="18sp" />

        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvCoverSwipeHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="32dp"
            android:fontFamily="@font/indie_flower"
            android:textColor="#888888"
            android:textSize="16sp" />

    </FrameLayout>
</FrameLayout>
