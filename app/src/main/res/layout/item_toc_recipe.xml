<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="44dp"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:paddingEnd="4dp">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="18dp"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="@string/toc_bullet"
        android:textColor="@color/book_accent_soft"
        android:textSize="15sp" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvTocTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:fontFamily="serif"
        android:maxLines="1"
        android:textColor="@color/book_ink"
        android:textSize="16sp" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="@string/toc_dots"
        android:textColor="@color/book_rule_line"
        android:textSize="15sp" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvTocPage"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:gravity="end"
        android:textColor="@color/book_note_ink"
        android:textSize="15sp"
        android:textStyle="italic" />

</LinearLayout>
