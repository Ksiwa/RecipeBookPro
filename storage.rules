rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Profil Resimleri: Herkes okuyabilir (tariflerin yanında avatar görünmesi için),
    // fakat sadece resmin sahibi olan oturum açmış kullanıcı yazabilir/silebilir.
    match /profile_images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && fileName == request.auth.uid + '.jpg';
    }
    
    // Yemek Kitabı Kapak Resimleri: Herkes okuyabilir (paylaşılan kitaplar için),
    // sadece oturum açmış kullanıcılar yeni kapak resmi yükleyebilir veya güncelleyebilir.
    match /cookbooks/{cookbookId}/cover.jpg {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Tarif Resimleri: Herkes okuyabilir (tarifler herkese açık veya paylaşımlı olabilir),
    // sadece oturum açmış kullanıcılar tarif resmi yükleyebilir veya güncelleyebilir.
    match /recipes/{recipeId}/main.jpg {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Varsayılan kural: Yukarıdaki kurallara uymayan diğer tüm dosya yollarına erişimi engelle.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
